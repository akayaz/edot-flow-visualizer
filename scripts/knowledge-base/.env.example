# Elasticsearch
ELASTICSEARCH_URL=https://<deployment>.es.us-east-1.aws.cloud.es.io
ELASTICSEARCH_API_KEY=<base64-encoded-api-key>
# Optional aliases used by crawler configs
ES_HOST=${ELASTICSEARCH_URL}
ES_API_KEY=${ELASTICSEARCH_API_KEY}

# GitHub
GITHUB_TOKEN=<github-personal-access-token>
JINA_API_KEY=<your-jina-api-key>
# VOYAGEAI_API_KEY=<optional-fallback-for-voyage-code-3>

# Agent Builder
AGENT_BUILDER_URL=https://<deployment>.elastic.cloud
AGENT_BUILDER_API_KEY=<api-key>

# Optional
LOG_LEVEL=INFO
DRY_RUN=false
