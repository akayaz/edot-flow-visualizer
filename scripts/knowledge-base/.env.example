# Elasticsearch
ELASTICSEARCH_URL=https://<deployment>.es.us-east-1.aws.cloud.es.io
ELASTICSEARCH_API_KEY=<base64-encoded-api-key>

# Jina Reader
JINA_API_KEY=<jina-api-key>

# GitHub
GITHUB_TOKEN=<github-personal-access-token>

# Agent Builder
AGENT_BUILDER_URL=https://<deployment>.elastic.cloud
AGENT_BUILDER_API_KEY=<api-key>

# Optional
LOG_LEVEL=INFO
DRY_RUN=false
