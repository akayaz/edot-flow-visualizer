# EDOT Flow Visualizer - Environment Variables
# Copy this to .env.local and fill in your values

# Elastic APM Configuration (for OTLP ingestion - Phase 2)
ELASTIC_APM_ENDPOINT=https://your-deployment.apm.us-east-1.aws.cloud.es.io:443
ELASTIC_APM_SECRET_TOKEN=your-secret-token

# Optional: Enable demo mode by default
NEXT_PUBLIC_DEMO_MODE=true
